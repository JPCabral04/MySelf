generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// USUÁRIO & CATEGORIAS
// ==========================================

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  profilePicture String
  createdAt      DateTime @default(now())

  agendaItems       AgendaItem[]
  financialItems    FinancialItem[]
  activities        Activity[]
  categoriesCreated Category[]
}

model Category {
  id         String @id @default(cuid())
  name       String
  hexColor   String
  moduleType String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tasks        Task[]
  transactions Transaction[]
}

// ==========================================
// AGENDA MODULE
// ==========================================

enum AgendaType {
  TASK
  EVENT
}

model AgendaItem {
  id          String @id @default(cuid())
  title       String
  description String

  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        AgendaType
  event       Event?     @relation("agendaEvent")
  task        Task?      @relation("agendaTask")
}

model Task {
  agendaItemId String     @id
  agendaItem   AgendaItem @relation("agendaTask", fields: [agendaItemId], references: [id], onDelete: Cascade)
  
  dueDate      DateTime
  priority     String
  isCompleted  Boolean

  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id])
}

model Event {
  agendaItemId  String     @id
  agendaItem    AgendaItem @relation("agendaEvent", fields: [agendaItemId], references: [id], onDelete: Cascade)
  
  startDate     DateTime
  endDate       DateTime
  googleEventId String
}

// ==========================================
// FINANCIAL MODULE
// ==========================================

enum FinancialType {
  TRANSACTION
  GOAL
  INVESTMENT
}

model FinancialItem {
  id     String @id @default(cuid())
  amount Float

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        FinancialType
  transaction Transaction?  @relation("financialTransaction")
  goal        Goal?         @relation("financialGoal")
  investment  Investment?   @relation("financialInvestment")
}

model Transaction {
  financialItemId String        @id
  financialItem   FinancialItem @relation("financialTransaction", fields: [financialItemId], references: [id], onDelete: Cascade)
  
  transactionType String
  date            DateTime
  description     String

  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id])
}

model Goal {
  financialItemId String        @id
  financialItem   FinancialItem @relation("financialGoal", fields: [financialItemId], references: [id], onDelete: Cascade)
  
  title           String
  targetAmount    Float
  targetDate      DateTime
}

model Investment {
  financialItemId String        @id
  financialItem   FinancialItem @relation("financialInvestment", fields: [financialItemId], references: [id], onDelete: Cascade)
  
  assetName       String
  estimatedReturn Float
}

// ==========================================
// ACTIVITY MODULE
// ==========================================

enum ActivityType {
  HABIT
}

model Activity {
  id          String @id @default(cuid())
  name        String
  description String

  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        ActivityType
  habitModule HabitModule? @relation("activityHabit")
}

model HabitModule {
  activityId    String   @id
  activity      Activity @relation("activityHabit", fields: [activityId], references: [id], onDelete: Cascade)
  
  notes         String
  currentStreak Int

  dailyRecords  DailyRecord[]
}

model DailyRecord {
  id          String   @id @default(cuid())
  date        DateTime
  isCompleted Boolean

  habitId String
  habit   HabitModule @relation(fields: [habitId], references: [activityId], onDelete: Cascade)
}